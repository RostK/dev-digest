node_modules/
dist/
# agent-runner ships as a JS GitHub Action — its bundled dist/ MUST be committed
# (GitHub runs action.yml `main: dist/index.js` as-is, with no build step).
!agent-runner/dist/
!agent-runner/dist/**
build/
.next/
out/
coverage/
*.tsbuildinfo
.env
.env.local
.DS_Store
.idea/
.turbo/
.pnpm-store/
*.log
.devdigest/cache/
clones/
playwright-report/
test-results/

# emdash worktree config (local)
.emdash.json

# pr-self-review local verdict cache (per-machine, not shared)
.claude/.pr-self-review-state.json

# pnpm per-package native-build-script approvals (per-machine, local; this repo
# is NOT a pnpm workspace — see CLAUDE.md. pnpm regenerates these on install.)
client/pnpm-workspace.yaml
server/pnpm-workspace.yaml
